  "components": {
    "schemas": {
      "ChangePasswordRequest": {
        "type": "object",
        "properties": {
          "oldPassword": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "newPassword": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "userName": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "password": {
            "maxLength": 20,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "OrderRequest": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer",
            "format": "int32"
          },
          "quantity": {
            "maximum": 100000,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "tradeMark": {
            "maxLength": 50,
            "minLength": 2,
            "type": "string",
            "nullable": true
          },
          "price": {
            "maximum": 10000000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "quantity": {
            "maximum": 100000,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "type": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "addToStoreDate": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "maxLength": 20,
            "type": "string",
            "nullable": true
          },
          "pictureProduct": {
            "maxLength": 255,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "userName": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "password": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "userBornDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Input JWT Token",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
